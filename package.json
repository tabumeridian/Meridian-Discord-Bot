{
  "name": "meridian-discord-bot",
  "version": "0.1.0",
  "description": "Discord bot foundation for the Meridian Arma Reforger Life community.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "register:guild": "tsx src/scripts/registerCommands.ts guild",
    "register:global": "tsx src/scripts/registerCommands.ts global"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0"
  }
}
